{
  "manifest_version": 3,
  "name": "Warmline — LinkedIn Mutuals",
  "version": "0.1.0",
  "description": "Reads the mutual connections shown on a LinkedIn profile (the connectors on a Lead's warm path) and sends them to Warmline.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://*.convex.site/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Warmline",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
