# Copy to .env.local and fill in. NEVER put real keys here — .env.example is committed.

# --- Convex deploy (Production/Preview only; not needed for local dev) ---
# Create at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# --- Frontend (.env.local) ---
# Set automatically by `npm run dev`. Shown here for reference.
# NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# --- Server secrets ---
# Read by Convex ACTIONS, so they do NOT go in .env.local.
# Set them on the Convex deployment instead:
#   npx convex env set FIBER_API_KEY sk_live_xxxxxxxx
#   npx convex env set OPENAI_API_KEY sk-xxxxxxxx
# Listed here only so teammates know what to provision (example values, not real).
FIBER_API_KEY=sk_live_xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
